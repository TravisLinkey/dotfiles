# Default GitHub (liftskit account)
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_liftskit
    IdentitiesOnly yes

# Servicecore organization (travis-linkey-servicecore account)
Host github.com-servicecore
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_servicecore
    IdentitiesOnly yes

# Bitbucket (servicecore account)
Host bitbucket.org
    HostName bitbucket.org
    User git
    IdentityFile ~/.ssh/id_ed25519_servicecore
    IdentitiesOnly yes
